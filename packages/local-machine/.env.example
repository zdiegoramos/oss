# packages/local-machine/.env.example
# Copy to .env and fill in your values before running `bun run start`.

# Port the Bun ping server listens on.
# Cloudflared will forward tunnel traffic to http://localhost:<this port>.
LOCAL_MACHINE_PORT=7001

# Token from: cloudflared tunnel token <tunnel-name>
# See GUIDE.md Step 3.
CF_TUNNEL_TOKEN=

# Public hostname you routed to this tunnel in Step 4 (log line only).
# e.g. ping.yourdomain.com
CF_TUNNEL_HOSTNAME=

CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
