{
  "name": "oss",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@better-auth/expo": "^1.5.6",
      "@better-auth/passkey": "^1.5.6",
      "@icons-pack/react-simple-icons": "^13.13.0",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/server": "^1.12.2",
      "@orpc/tanstack-query": "^1.13.6",
      "nanoid": "^5.1.9",
      "@orpc/zod": "^1.12.2",
      "@polar-sh/better-auth": "^1.8.3",
      "@react-email/components": "^1.0.11",
      "@react-email/render": "^2.0.5",
      "@tanstack/react-form": "^1.28.0",
      "@tanstack/react-query": "^5.90.12",
      "@types/react-dom": "^19.2.3",
      "better-auth": "^1.5.6",
      "@faker-js/faker": "^9.8.0",
      "dotenv": "^17.2.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "next": "^16.2.0",
      "resend": "^6.10.0",
      "sonner": "^2.0.5",
      "zod": "^4.1.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "ts": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:finance": "turbo -F finance dev",
    "db:push": "turbo -F @oss/db db:push",
    "db:studio": "turbo -F @oss/db db:studio",
    "db:generate": "turbo -F @oss/db db:generate",
    "lint": "biome check --write .",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "box": "bun .sandcastle/main.ts"
  },
  "dependencies": {
    "@oss/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.2.3",
    "@biomejs/biome": "2.4.10",
    "@oss/config": "workspace:*",
    "@types/node": "^22.13.14",
    "husky": "latest",
    "lint-staged": "latest",
    "playwright": "^1.59.1",
    "portless": "^0.10.3",
    "turbo": "^2.9.6",
    "typescript": "^5",
    "ultracite": "7.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.2.17"
}
