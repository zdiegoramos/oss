    "nanoid": "^5.1.7",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-email": "^5.2.10",
    "react-resizable-panels": "^4.8.0",
