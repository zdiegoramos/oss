{
  "name": "stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "ultracite check",
    "check:unsafe": "biome check --write --unsafe .",
    "lint": "biome check --write .",
    "dev": "next dev --turbo",
    "preview": "next build && next start",
    "start": "next start",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
